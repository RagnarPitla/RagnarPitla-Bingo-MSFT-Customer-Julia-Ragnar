{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/matching-game/*.{css,js,svg,png,jpg,jpeg,gif,ico,json,txt,woff,woff2}", "/matching-game/assets/*"]
  },
  "routes": [
    {
      "route": "/matching-game",
      "rewrite": "/matching-game/index.html"
    },
    {
      "route": "/matching-game/",
      "rewrite": "/matching-game/index.html"
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Content-Security-Policy": "default-src 'self' https://*.supabase.co; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co"
  }
}
